---
---

<div class="chat-widget" id="chat-widget">
  <!-- Chat Button Trigger -->
  <button id="chat-trigger" class="chat-trigger" aria-label="Abrir chat con Nova">
    <div class="chat-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </div>
    <span>Chatea con Nova</span>
  </button>

  <!-- Chat Window -->
  <div id="chat-window" class="chat-window">
    <div class="chat-header">
      <div class="chat-header-info">
        <div class="bot-avatar">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="avatar-svg">
            <circle cx="12" cy="12" r="12" fill="url(#bot-grad)"/>
            <path d="M12 6V18M12 6L8 10M12 6L16 10" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="bot-grad" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
                <stop stop-color="#3A3DEE"/>
                <stop offset="1" stop-color="#15C63B"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="header-text">
          <h3>Nova AI</h3>
          <p>En línea • Soporte Inteligente</p>
        </div>
      </div>
      <div class="chat-header-actions">
        <button id="expand-chat" class="header-action-btn" title="Expandir">
          <svg id="expand-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 3 21 3 21 9"></polyline>
            <polyline points="9 21 3 21 3 15"></polyline>
            <line x1="21" y1="3" x2="14" y2="10"></line>
            <line x1="3" y1="21" x2="10" y2="14"></line>
          </svg>
          <svg id="shrink-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 14 10 14 10 20"></polyline>
            <polyline points="20 10 14 10 14 4"></polyline>
            <line x1="14" y1="10" x2="21" y2="3"></line>
            <line x1="10" y1="14" x2="3" y2="21"></line>
          </svg>
        </button>
        <button id="close-chat" class="header-action-btn close-chat" title="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div class="chat-body">
      <div class="message bot">
        <div class="message-content">
          ¡Hola! Soy Nova. ¿En qué puedo ayudarte hoy con la automatización de tus mensajes?
        </div>
        <span class="message-time">Recién</span>
      </div>
    </div>

    <div class="chat-footer">
      <input type="text" id="chat-input" placeholder="Escribe un mensaje..." class="chat-input" />
      <button id="send-btn" class="send-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  .chat-widget {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
    font-family: 'Inter', sans-serif;
  }

  .chat-trigger {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    background: linear-gradient(135deg, #3A3DEE 0%, #2528c7 100%);
    color: white;
    border: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(58, 61, 238, 0.3);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  .chat-trigger:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 15px 30px rgba(58, 61, 238, 0.4);
    animation-play-state: paused;
  }

  .chat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .chat-window {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: 350px;
    height: 500px;
    background: white;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(20px) scale(0.9);
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform-origin: bottom right;
  }

  .chat-window.active {
    transform: translateY(0) scale(1);
    opacity: 1;
    pointer-events: all;
  }

  .chat-header {
    padding: 20px;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .bot-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .header-text h3 {
    font-size: 16px;
    margin: 0;
    font-weight: 700;
  }

  .header-text p {
    font-size: 11px;
    margin: 0;
    opacity: 0.8;
  }

  .chat-header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header-action-btn {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    border-radius: 4px;
  }

  .header-action-btn:hover {
    color: white;
    background: rgba(255,255,255,0.1);
  }

  .hidden { display: none !important; }

  .chat-window.expanded {
    width: 500px;
    height: 700px;
    max-height: 85vh;
  }

  .close-chat:hover { color: #ff4d4f; }

  .chat-body {
    flex: 1;
    padding: 20px;
    background-color: #f8fafc;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .message {
    max-width: 85%;
    display: flex;
    flex-direction: column;
    margin-bottom: 4px;
  }

  .message.bot {
    align-self: flex-start;
    align-items: flex-start;
  }

  .message.user {
    align-self: flex-end;
    align-items: flex-end;
  }

  .message-content {
    padding: 12px 16px;
    border-radius: 18px;
    font-size: 14px;
    line-height: 1.5;
    word-wrap: break-word;
  }

  .bot .message-content {
    background-color: #E5E7EB !important; /* Gris claro */
    color: #1F2937 !important; /* Gris oscuro para texto */
    border-bottom-left-radius: 4px;
  }

  .user .message-content {
    background-color: #3A3DEE !important; /* Azul de la página */
    color: #FFFFFF !important; /* Texto blanco */
    border-bottom-right-radius: 4px;
  }

  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    background-color: #E5E7EB !important;
    border-radius: 18px;
    border-bottom-left-radius: 4px;
    width: fit-content;
  }

  .typing-dot {
    width: 6px;
    height: 6px;
    background-color: #6B7280;
    border-radius: 50%;
    animation: typing-bounce 1.4s infinite ease-in-out both;
  }

  .typing-dot:nth-child(1) { animation-delay: -0.32s; }
  .typing-dot:nth-child(2) { animation-delay: -0.16s; }

  @keyframes typing-bounce {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1.0); }
  }

  .message-time {
    font-size: 10px;
    color: #6B7280;
    margin-top: 4px;
    padding: 0 4px;
  }

  .chat-footer {
    padding: 15px 20px;
    background: white;
    border-top: 1px solid #e2e8f0;
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .chat-input {
    flex: 1;
    border: none;
    padding: 8px 0;
    font-size: 14px;
    outline: none;
    background: transparent;
  }

  .send-button {
    background: #3A3DEE;
    color: white;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
  }

  .send-button:hover { background: #2528c7; }

  @media (max-width: 640px) {
    .chat-widget { bottom: 20px; right: 20px; }
    .chat-trigger span { display: none; }
    .chat-trigger { padding: 16px; border-radius: 50%; }
    .chat-window { width: calc(100vw - 40px); right: 0; height: 400px; }
  }
</style>

<script>
  // DOM Elements
  const trigger = document.getElementById('chat-trigger');
  const closeBtn = document.getElementById('close-chat');
  const chatWindow = document.getElementById('chat-window');
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('send-btn');
  const chatBody = document.querySelector('.chat-body');

  // --- Logic Functions ---

  /**
   * Obtiene la hora actual en formato HH:MM
   */
  function getCurrentTime(): string {
    const now = new Date();
    return now.getHours().toString().padStart(2, '0') + ':' + 
           now.getMinutes().toString().padStart(2, '0');
  }

  /**
   * Genera una respuesta basada en el mensaje del usuario
   */
  function getBotResponse(input: string): string {
    const msg = input.toLowerCase();
    const menuFooter = `<br><br>⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯<br>🏠 Escribí <b>'menu'</b> para volver al inicio.`;

    // MENÚ PRINCIPAL
    if (msg.includes('hola') || msg.includes('buenas') || msg.includes('info') || msg.includes('inicio') || msg.includes('menu')) {
      return `¡Hola de nuevo! 😊 Soy <b>Nova</b>, tu asistente de MM SmartInbox.<br><br>
      Estoy aquí para ayudarte a transformar la comunicación de tu negocio con automatizaciones inteligentes. ¿Qué información necesitás hoy?<br><br>
      <b>1. 💳 Precios y Planes Detallados</b><br>
      <i>Conocé cuál se adapta mejor a tu equipo.</i><br><br>
      <b>2. ⏰ Horarios y Tiempos de Respuesta</b><br>
      <i>Saber más sobre nuestra disponibilidad.</i><br><br>
      <b>3. 💬 Soporte Personalizado</b><br>
      <i>Hablá con un humano ahora mismo.</i><br><br>
      Escribí el <b>número</b> o la <b>palabra</b> clave.`;
    }
    
    // OPCIÓN 1: PRECIOS
    if (msg.includes('1') || msg.includes('precio') || msg.includes('plan')) {
      return `<b>💳 Nuestros Planes y Tarifas:</b><br><br>
      • <b>Plan Emprendedor ($8.500/mes):</b><br>
      Ideal para 1 usuario. Incluye 1 bot básico y hasta 500 mensajes mensuales.<br><br>
      • <b>Plan Business ($15.000/mes):</b><br>
      Hasta 5 usuarios. Bots ilimitados, integración con CRM y 5.000 mensajes mensuales.<br><br>
      • <b>Plan Corporate (Consultar):</b><br>
      Usuarios ilimitados, API de WhatsApp Business oficial y soporte dedicado 24/7.<br><br>
      <i>*Todos los planes incluyen una prueba gratuita de 7 días.</i>` + menuFooter;
    }

    // OPCIÓN 2: HORARIOS
    if (msg.includes('2') || msg.includes('horario')) {
      return `<b>⏰ Disponibilidad de Servicio:</b><br><br>
      En <b>MM SmartInbox</b> entendemos que tu negocio no frena. Por eso:<br><br>
      • <b>Nova (Asistente IA):</b> Disponible los 365 días del año, las 24 horas. Responde al instante.<br><br>
      • <b>Soporte Técnico Humano:</b><br>
      Lunes a Viernes: 08:30 a 19:30 hs.<br>
      Sábados: 09:00 a 14:00 hs.<br><br>
      <i>Si dejas un mensaje fuera de hora, un asesor te contactara apenas iniciemos la jornada.</i>` + menuFooter;
    }

    // OPCIÓN 3: CONTACTO
    if (msg.includes('3') || msg.includes('contacto') || msg.includes('soporte') || msg.includes('humano')) {
      return `<b>💬 Canales de Comunicación Directa:</b><br><br>
      ¿Preferís hablar con una persona? ¡Claro! Elegí el medio que más te guste:<br><br>
      • <b>WhatsApp Express:</b> +54 9 11 9876-5432.<br>
      • <b>Llamada Directa:</b> 0800-555-SMART.<br>
      • <b>Email de Ventas:</b> ventas@mmsmartinbox.com<br><br>
      <b>¿En qué zona te encontrás?</b> Podés indicarnos tu ciudad para derivarte al representante más cercano.` + menuFooter;
    }

    return `Ups, no pude entender <b>"${input}"</b>. 😕<br><br>
    Soy un bot en entrenamiento. Por favor, intentá con:<br>
    • Escribir <b>"Hola"</b> para ver el menú.<br>
    • Escribir <b>"1"</b> para ver precios.<br>
    • Escribir <b>"3"</b> para hablar con un humano.` + menuFooter;
  }

  /**
   * Agrega un mensaje al DOM del chat
   */
  function addMessage(text: string, sender: 'bot' | 'user'): void {
    if (!chatBody) return;

    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${sender}`;
    
    messageDiv.innerHTML = `
      <div class="message-content">
        ${text}
      </div>
      <span class="message-time">${getCurrentTime()}</span>
    `;

    chatBody.appendChild(messageDiv);
    
    // Auto-scroll al final
    chatBody.scrollTop = chatBody.scrollHeight;
  }

  /**
   * Muestra el indicador de 'escribiendo'
   */
  function showTypingIndicator(): HTMLElement | null {
    if (!chatBody) return null;

    const indicatorDiv = document.createElement('div');
    indicatorDiv.className = 'message bot typing-message';
    indicatorDiv.innerHTML = `
      <div class="typing-indicator">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    `;

    chatBody.appendChild(indicatorDiv);
    chatBody.scrollTop = chatBody.scrollHeight;
    return indicatorDiv;
  }

  /**
   * Procesa el envío de un mensaje
   */
  function handleSendMessage(): void {
    const text = chatInput.value.trim();
    if (!text) return;

    // 1. Mensaje del usuario
    addMessage(text, 'user');
    chatInput.value = '';

    // 2. Mostrar indicador de escritura
    const indicator = showTypingIndicator();

    // 3. Respuesta del bot con delay de 2 segundos
    setTimeout(() => {
      if (indicator) indicator.remove();
      const response = getBotResponse(text);
      addMessage(response, 'bot');
    }, 2000);
  }

  // --- Event Listeners ---

  const expandBtn = document.getElementById('expand-chat');
  const expandIcon = document.getElementById('expand-icon');
  const shrinkIcon = document.getElementById('shrink-icon');

  if (trigger && chatWindow && closeBtn && expandBtn) {
    // Toggle ventana
    trigger.addEventListener('click', () => {
      chatWindow.classList.toggle('active');
      if (chatWindow.classList.contains('active')) {
        chatInput.focus();
      }
    });

    closeBtn.addEventListener('click', () => {
      chatWindow.classList.remove('active');
    });

    // Expandir / Achicar
    expandBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      chatWindow.classList.toggle('expanded');
      
      if (expandIcon && shrinkIcon) {
        expandIcon.classList.toggle('hidden');
        shrinkIcon.classList.toggle('hidden');
      }
    });

    // Cerrar al hacer clic fuera
    document.addEventListener('click', (e) => {
      if (!chatWindow.contains(e.target as Node) && !trigger.contains(e.target as Node)) {
        chatWindow.classList.remove('active');
      }
    });
  }

  // Enviar mensaje
  if (sendBtn && chatInput) {
    sendBtn.addEventListener('click', handleSendMessage);
    
    chatInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        handleSendMessage();
      }
    });
  }
</script>
