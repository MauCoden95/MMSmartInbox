---
// src/components/TrialModal.astro
---

<div id="trial-modal" class="trial-modal">
  <div class="modal-overlay" id="trial-overlay"></div>
  <div class="modal-content">
    <button class="close-modal" id="close-trial" aria-label="Cerrar">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    
    <div class="trial-header">
      <div class="trial-bot-avatar">
        <img src="/images/Robot.png" alt="Nova AI" />
        <div class="online-indicator"></div>
      </div>
      <div class="trial-header-text">
        <h2>Configurador de Prueba <span>Nova</span></h2>
        <p>Vamos a diseñar tu automatización ideal</p>
      </div>
    </div>

    <div class="trial-chat-body" id="trial-chat-body">
      <!-- Mensajes dinámicos aquí -->
    </div>

    <div class="trial-chat-footer">
      <textarea id="trial-input" placeholder="Escribe tu tipo de negocio..." rows="1"></textarea>
      <button id="trial-send" class="trial-send-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  .trial-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    font-family: 'Inter', sans-serif;
  }

  .trial-modal.active {
    opacity: 1;
    pointer-events: all;
  }

  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(8px);
  }

  .modal-content {
    position: relative;
    width: 100%;
    max-width: 600px;
    height: 80vh;
    background: white;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: translateY(20px) scale(0.95);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .trial-modal.active .modal-content {
    transform: translateY(0) scale(1);
  }

  .close-modal {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(15, 23, 42, 0.05);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.2s;
    color: #475569;
  }

  .close-modal:hover {
    background: #ef4444;
    color: white;
    transform: rotate(90deg);
  }

  .trial-header {
    padding: 30px;
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .trial-bot-avatar {
    position: relative;
    width: 60px;
    height: 60px;
    background: white;
    border-radius: 18px;
    padding: 8px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .trial-bot-avatar img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .online-indicator {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 14px;
    height: 14px;
    background: #22c55e;
    border: 3px solid white;
    border-radius: 50%;
  }

  .trial-header-text h2 {
    font-size: 20px;
    margin: 0;
    color: #1e293b;
    font-weight: 800;
  }

  .trial-header-text h2 span {
    color: #3A3DEE;
  }

  .trial-header-text p {
    font-size: 14px;
    margin: 4px 0 0;
    color: #64748b;
  }

  .trial-chat-body {
    flex: 1;
    padding: 30px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
    background-color: #ffffff;
  }

  .trial-message {
    max-width: 85%;
    display: flex;
    flex-direction: column;
    animation: slideUp 0.3s ease-out;
  }

  .trial-message.bot {
    align-self: flex-start;
    align-items: flex-start;
  }

  .trial-message.user {
    align-self: flex-end;
    align-items: flex-end;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .trial-message-content {
    font-size: 14px;
    line-height: 1.5;
    word-wrap: break-word;
  }

  .trial-message.bot .trial-message-content {
    background-color: #E5E7EB !important;
    color: #1F2937 !important;
    padding: 12px 16px;
    border-radius: 18px;
    border-bottom-left-radius: 4px;
  }

  .trial-message.user .trial-message-content {
    background-color: #3A3DEE !important;
    color: #FFFFFF !important;
    padding: 12px 16px;
    border-radius: 18px;
    border-bottom-right-radius: 4px;
  }

  .trial-message-time {
    font-size: 10px;
    color: #6B7280;
    margin-top: 4px;
    padding: 0 4px;
  }

  .trial-typing-indicator {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    background-color: #E5E7EB !important;
    border-radius: 18px;
    border-bottom-left-radius: 4px;
    width: fit-content;
  }

  .trial-chat-footer {
    padding: 24px 30px;
    background: white;
    border-top: 1px solid #e2e8f0;
    display: flex;
    gap: 15px;
    align-items: flex-end;
  }

  #trial-input {
    flex: 1;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 12px 16px;
    font-family: inherit;
    font-size: 15px;
    resize: none;
    outline: none;
    transition: all 0.2s;
    max-height: 100px;
  }

  #trial-input:focus {
    border-color: #3A3DEE;
    background: white;
    box-shadow: 0 0 0 4px rgba(58, 61, 238, 0.05);
  }

  .trial-send-btn {
    background: #3A3DEE;
    color: white;
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }

  .trial-send-btn:hover {
    background: #2528c7;
    transform: translateY(-2px);
  }

  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 10px;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: #cbd5e1;
    border-radius: 50%;
    animation: bounce 1.4s infinite ease-in-out;
  }

  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1); }
  }

  @media (max-width: 640px) {
    .modal-content {
      height: 100%;
      max-height: 100%;
      border-radius: 0;
    }
  }
</style>

<script>
  const modal = document.getElementById('trial-modal');
  const overlay = document.getElementById('trial-overlay');
  const closeBtn = document.getElementById('close-trial');
  const chatBody = document.getElementById('trial-chat-body');
  const input = document.getElementById('trial-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('trial-send');

  let currentStep = 0;

  function getCurrentTime(): string {
    const now = new Date();
    return now.getHours().toString().padStart(2, '0') + ':' + 
           now.getMinutes().toString().padStart(2, '0');
  }

  function addTrialMessage(text: string, sender: 'bot' | 'user') {
    if (!chatBody) return;
    const msg = document.createElement('div');
    msg.className = `trial-message ${sender}`;
    msg.innerHTML = `
      <div class="trial-message-content">
        ${text}
      </div>
      <span class="trial-message-time">${getCurrentTime()}</span>
    `;
    chatBody.appendChild(msg);
    chatBody.scrollTop = chatBody.scrollHeight;
  }

  function showTyping() {
    if (!chatBody) return null;
    const typing = document.createElement('div');
    typing.className = 'trial-message bot typing';
    typing.innerHTML = `
      <div class="trial-typing-indicator">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
    `;
    chatBody.appendChild(typing);
    chatBody.scrollTop = chatBody.scrollHeight;
    return typing;
  }

  async function botReply(text: string) {
    const typing = showTyping();
    await new Promise(r => setTimeout(r, 1500));
    if (typing) typing.remove();
    
    let response = "";
    const lowerText = text.toLowerCase();

    if (currentStep === 0) {
      if (lowerText.includes('e-commerce') || lowerText.includes('tienda') || lowerText.includes('venta')) {
        response = `¡Genial! Un <b>E-commerce</b>. 🛒 Para tu negocio, puedo automatizar:<br><br>
        1. 📦 <b>Tracking de envíos:</b> Los clientes sabrán dónde está su pedido al instante.<br>
        2. 🛒 <b>Recuperación de Carrito:</b> Enviaré un mensaje persuasivo si dejan una compra a medias.<br>
        3. ❓ <b>FAQs:</b> Responderé dudas sobre talles, stock o medios de pago 24/7.<br><br>
        ¿Te gustaría que probemos enviar un mensaje de prueba a tu WhatsApp?`;
      } else if (lowerText.includes('inmo') || lowerText.includes('casa') || lowerText.includes('depto')) {
        response = `¡Excelente! El sector <b>Inmobiliario</b> 🏠 se beneficia mucho de la inmediatez. Mi plan para vos es:<br><br>
        1. 📅 <b>Agendamiento de Visitas:</b> Los interesados podrán elegir horario directamente en el chat.<br>
        2. 🔍 <b>Filtros Inteligentes:</b> Les preguntaré presupuesto y zona antes de pasarlos a un humano.<br>
        3. 📸 <b>Envío de Fichas:</b> Puedo enviar PDFs de propiedades automáticamente al recibir una consulta.<br><br>
        ¿Querés ver cómo se vería tu calendario automatizado?`;
      } else if (lowerText.includes('estética') || lowerText.includes('salud') || lowerText.includes('turno') || lowerText.includes('peluquería')) {
        response = `¡Perfecto! Para <b>Servicios de Salud o Estética</b> 💅 la clave es el orden. Aquí mi propuesta:<br><br>
        1. 🗓️ <b>Gestión de Turnos:</b> Nova reserva el espacio y lo sincroniza con tu Google Calendar.<br>
        2. 🔔 <b>Recordatorios:</b> Enviaré un mensaje 2 horas antes para reducir archivos ausentes en un 40%.<br>
        3. ✨ <b>Promociones:</b> Podés avisar de nuevos tratamientos a todos tus clientes con un clic.<br><br>
        ¿Te interesa probar el sistema de recordatorios ahora?`;
      } else {
        response = `Interesante sector 🚀 En <b>${text}</b>, Nova puede ayudarte a que ningún cliente se quede sin respuesta. <br><br>
        Puedo calificar tus prospectos, responder dudas frecuentes y derivar solo los casos importantes a tu equipo.<br><br>
        <b>¿Qué es lo que más te quita tiempo hoy: responder precios, agendar citas o soporte técnico?</b>`;
      }
      currentStep = 1;
    } else {
      response = `¡Entendido! Me pongo manos a la obra. 🛠️ Estamos preparando tu entorno de prueba personalizado.<br><br>
      Mientras tanto, por favor dejame tu <b>Email o WhatsApp</b> para enviarte el acceso a tu panel de control.`;
    }

    addTrialMessage(response, 'bot');
  }

  function handleSend() {
    const text = input.value.trim();
    if (!text) return;
    
    addTrialMessage(text, 'user');
    input.value = '';
    botReply(text);
  }

  if (sendBtn && input) {
    sendBtn.addEventListener('click', handleSend);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        handleSend();
      }
    });
  }

  // API Global para abrir este modal específico
  (window as any).openTrialModal = () => {
    if (!modal || !chatBody) return;
    modal.classList.add('active');
    
    // Reiniciar si estaba abierto antes
    chatBody.innerHTML = '';
    currentStep = 0;
    
    setTimeout(() => {
      addTrialMessage("¡Bienvenido! 👋 Soy Nova. Para configurar tu prueba gratuita personalizada, primero decime: <b>¿Qué tipo de negocio tienes o quieres automatizar?</b> (Ej. Gastronomía, Educación/Cursos, Concesionarias)", 'bot');
    }, 600);
  };

  [closeBtn, overlay].forEach(el => {
    el?.addEventListener('click', () => modal?.classList.remove('active'));
  });
</script>
