---
// src/components/QuoteModal.astro
---

<div id="quote-modal" class="modal-overlay">
  <div class="modal-content">
    <button class="close-btn" id="close-modal" aria-label="Cerrar modal">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="modal-header">
      <h2>Solicitar Cotización</h2>
      <p>Completá el formulario y nos pondremos en contacto con vos a la brevedad.</p>
    </div>
    <form id="quote-form">
      <div class="form-group">
        <label for="name">Nombre completo</label>
        <input type="text" id="name" name="name" placeholder="Tu nombre" required />
        <span class="error-msg" id="name-error">Este campo es obligatorio</span>
      </div>
      <div class="form-group">
        <label for="email">Correo electrónico</label>
        <input type="email" id="email" name="email" placeholder="tu@email.com" required />
        <span class="error-msg" id="email-error">Ingresá un email válido</span>
      </div>
      <div class="form-group">
        <label for="message">¿Qué estás buscando?</label>
        <textarea id="message" name="message" rows="4" placeholder="Contanos sobre tu proyecto o necesidad" required></textarea>
        <span class="error-msg" id="message-error">Por favor, dejanos un mensaje</span>
      </div>
      <button type="submit" class="submit-btn" id="submit-quote">
        <span>Enviar solicitud</span>
        <div class="loader" id="form-loader"></div>
      </button>
    </form>
    <div id="success-msg" class="success-msg">
      <div class="success-icon">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="var(--color-primary-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h3>¡Mensaje enviado!</h3>
      <p>Gracias por contactarnos. Te responderemos pronto.</p>
      <button class="btn btn-primary" id="close-success">Cerrar</button>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('quote-modal');
  const closeBtn = document.getElementById('close-modal');
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-msg');
  const closeSuccess = document.getElementById('close-success');
  const loader = document.getElementById('form-loader');
  const submitBtnText = document.querySelector('#submit-quote span');

  function openModal() {
    modal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.classList.remove('active');
    document.body.style.overflow = '';
    // Reset form after a delay to wait for animation
    setTimeout(() => {
      form.reset();
      form.style.display = 'block';
      successMsg?.classList.remove('active');
      clearErrors();
    }, 300);
  }

  function clearErrors() {
    const inputs = form.querySelectorAll('input, textarea');
    inputs.forEach(input => input.classList.remove('invalid'));
    const errorMsgs = form.querySelectorAll('.error-msg');
    errorMsgs.forEach(msg => (msg as HTMLElement).style.display = 'none');
  }

  // Listen for custom event to open modal
  window.addEventListener('open-quote-modal', () => {
    openModal();
  });

  // Global click listener for elements with data-open-quote
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.matches('[data-open-quote]') || target.closest('[data-open-quote]')) {
      e.preventDefault();
      openModal();
    }
  });

  closeBtn?.addEventListener('click', closeModal);
  closeSuccess?.addEventListener('click', closeModal);

  // Close on backdrop click
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors();

      let isValid = true;
      const nameInput = document.getElementById('name') as HTMLInputElement;
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const messageInput = document.getElementById('message') as HTMLTextAreaElement;

      if (!nameInput.value.trim()) {
        nameInput.classList.add('invalid');
        (document.getElementById('name-error') as HTMLElement).style.display = 'block';
        isValid = false;
      }

      if (!emailInput.value.trim() || !/^\S+@\S+\.\S+$/.test(emailInput.value)) {
        emailInput.classList.add('invalid');
        (document.getElementById('email-error') as HTMLElement).style.display = 'block';
        isValid = false;
      }

      if (!messageInput.value.trim()) {
        messageInput.classList.add('invalid');
        (document.getElementById('message-error') as HTMLElement).style.display = 'block';
        isValid = false;
      }

      if (!isValid) return;

      // UI Feedback
      if (submitBtnText) (submitBtnText as HTMLElement).style.opacity = '0';
      loader?.classList.add('active');

      // Real submission using Formspree
      try {
        const formData = new FormData(form);
        const response = await fetch("https://formspree.io/f/meenqedg", { // Real Formspree ID confirmed by user
          method: "POST",
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          form.style.display = 'none';
          successMsg?.classList.add('active');
        } else {
          const data = await response.json();
          if (data.errors) {
            alert(data.errors.map((error: any) => error.message).join(", "));
          } else {
            alert("Hubo un problema al enviar el mensaje. Por favor, intentá de nuevo.");
          }
        }
      } catch (error) {
        alert("Error de conexión. Revisá tu internet e intentá de nuevo.");
      } finally {
        loader?.classList.remove('active');
        if (submitBtnText) (submitBtnText as HTMLElement).style.opacity = '1';
      }
    });
</script>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .modal-content {
    background: white;
    width: 90%;
    max-width: 500px;
    padding: 2.5rem;
    border-radius: 20px;
    position: relative;
    transform: translateY(20px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .modal-overlay.active .modal-content {
    transform: translateY(0);
  }

  .close-btn {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: #f1f5f9;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text-medium);
    transition: all 0.2s;
  }

  .close-btn:hover {
    background: #e2e8f0;
    color: var(--color-text-dark);
    transform: rotate(90deg);
  }

  .modal-header {
    margin-bottom: 2rem;
  }

  .modal-header h2 {
    font-size: 1.8rem;
    color: var(--color-text-dark);
    margin-bottom: 0.5rem;
  }

  .modal-header p {
    color: var(--color-text-medium);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text-dark);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 2px solid #f1f5f9;
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.2s;
    background: #f8fafc;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary-blue);
    background: white;
    box-shadow: 0 0 0 4px rgba(58, 61, 238, 0.1);
  }

  .form-group input.invalid,
  .form-group textarea.invalid {
    border-color: #ef4444;
    background: #fffafa;
  }

  .error-msg {
    display: none;
    color: #ef4444;
    font-size: 0.8rem;
    margin-top: 0.4rem;
    font-weight: 500;
  }

  .submit-btn {
    width: 100%;
    padding: 1rem;
    background: var(--color-primary-green);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .submit-btn:hover {
    background: #12ad33;
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(21, 198, 59, 0.3);
  }

  .loader {
    width: 20px;
    height: 20px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: spin 0.8s linear infinite;
    position: absolute;
    display: none;
  }

  .loader.active {
    display: block;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .success-msg {
    display: none;
    text-align: center;
    padding: 2rem 0;
  }

  .success-msg.active {
    display: block;
    animation: fadeIn 0.4s ease;
  }

  .success-icon {
    margin-bottom: 1.5rem;
    background: #e6f9ec;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    margin-right: auto;
  }

  .success-msg h3 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-dark);
  }

  .success-msg p {
    color: var(--color-text-medium);
    margin-bottom: 2rem;
  }

  .btn-primary {
    background-color: var(--color-primary-green);
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    border: none;
    cursor: pointer;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  @media (max-width: 480px) {
    .modal-content {
      padding: 1.5rem;
    }
    .modal-header h2 {
      font-size: 1.5rem;
    }
  }
</style>
