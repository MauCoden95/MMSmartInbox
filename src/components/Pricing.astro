---
// src/components/Pricing.astro
---
<section id="precios" class="pricing">
  <div class="pricing-container">
    <div class="pricing-badge">Precios</div>
    <h2>Planes que crecen <span>con tu negocio</span></h2>
    <p class="pricing-subtitle">Sin contratos largos. Cancelá cuando quieras. Empezá gratis y escalá según tus necesidades.</p>
    <div class="pricing-grid">
      <!-- Starter -->
      <div class="plan-card">
        <div class="plan-name">Starter</div>
        <div class="plan-desc">Ideal para emprendedores que recién empiezan.</div>
        <div class="plan-price"><span class="currency">$</span><span class="amount">0</span><span class="period">/mes</span></div>
        <ul class="features">
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>1 canal conectado</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>100 mensajes/mes</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Chatbot básico</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Soporte por email</li>
        </ul>
        <a href="#start" class="plan-btn">Empezar Gratis</a>
      </div>
      <!-- Pro -->
      <div class="plan-card popular">
        <div class="popular-badge">Más Popular</div>
        <div class="plan-name">Pro</div>
        <div class="plan-desc">Para negocios en crecimiento que necesitan más poder.</div>
        <div class="plan-price"><span class="currency">$</span><span class="amount">49</span><span class="period">/mes</span></div>
        <ul class="features">
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>3 canales conectados</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>5,000 mensajes/mes</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>IA avanzada + clasificación</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Reportes y analíticas</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Soporte prioritario</li>
        </ul>
        <a href="#start" class="plan-btn primary-btn">Empezar con Pro</a>
      </div>
      <!-- Enterprise -->
      <div class="plan-card">
        <div class="plan-name">Enterprise</div>
        <div class="plan-desc">Para empresas que necesitan escala y personalización total.</div>
        <div class="plan-price"><span class="currency">$</span><span class="amount">149</span><span class="period">/mes</span></div>
        <ul class="features">
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Canales ilimitados</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Mensajes ilimitados</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>IA personalizada + API</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Onboarding dedicado</li>
          <li><svg viewBox="0 0 24 24" width="18" height="18"><path d="M20 6L9 17l-5-5" stroke="var(--color-primary-green)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>Soporte 24/7 con manager</li>
        </ul>
        <a href="#start" class="plan-btn">Contactar Ventas</a>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing { padding: 7rem 0; background: linear-gradient(180deg, #ffffff 0%, #f8f9ff 100%); position: relative; overflow: hidden; }
  .pricing::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(58,61,238,0.03) 0%, transparent 60%); pointer-events: none; }
  .pricing-container { max-width: 1100px; width: 90%; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
  .pricing-badge { display: inline-block; background: linear-gradient(135deg, rgba(139,92,246,0.08), rgba(139,92,246,0.15)); color: #8b5cf6; padding: 0.5rem 1.5rem; border-radius: 50px; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 1.5rem; border: 1px solid rgba(139,92,246,0.12); }
  h2 { font-size: 2.8rem; font-weight: 800; line-height: 1.2; color: var(--color-text-dark); margin-bottom: 1.5rem; letter-spacing: -1px; }
  h2 span { background: linear-gradient(135deg, var(--color-primary-blue), #6366f1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .pricing-subtitle { font-size: 1.15rem; line-height: 1.7; color: var(--color-text-medium); max-width: 560px; margin: 0 auto 4rem; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; align-items: start; }
  .plan-card { background: white; border: 1px solid #f1f5f9; border-radius: 20px; padding: 2.5rem 2rem; text-align: left; transition: all 0.4s cubic-bezier(0.4,0,0.2,1); position: relative; overflow: hidden; }
  .plan-card:hover { transform: translateY(-6px); box-shadow: 0 20px 48px rgba(0,0,0,0.07); }
  .plan-card.popular { background: linear-gradient(135deg, #1e1b4b, #312e81); border-color: transparent; transform: scale(1.04); }
  .plan-card.popular:hover { transform: scale(1.04) translateY(-6px); box-shadow: 0 24px 56px rgba(30,27,75,0.3); }
  .popular-badge { position: absolute; top: 1rem; right: 1rem; background: linear-gradient(135deg, var(--color-primary-green), #22c55e); color: white; padding: 0.3rem 0.85rem; border-radius: 20px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .plan-name { font-size: 1.2rem; font-weight: 700; color: var(--color-text-dark); margin-bottom: 0.5rem; }
  .plan-card.popular .plan-name { color: white; }
  .plan-desc { font-size: 0.88rem; color: var(--color-text-medium); line-height: 1.5; margin-bottom: 1.5rem; }
  .plan-card.popular .plan-desc { color: rgba(255,255,255,0.6); }
  .plan-price { margin-bottom: 2rem; display: flex; align-items: baseline; gap: 0.15rem; }
  .currency { font-size: 1.5rem; font-weight: 700; color: var(--color-text-dark); }
  .amount { font-size: 3.5rem; font-weight: 800; color: var(--color-text-dark); line-height: 1; letter-spacing: -2px; }
  .period { font-size: 1rem; color: var(--color-text-light); font-weight: 500; margin-left: 0.25rem; }
  .plan-card.popular .currency, .plan-card.popular .amount { color: white; }
  .plan-card.popular .period { color: rgba(255,255,255,0.5); }
  .features { list-style: none; padding: 0; margin: 0 0 2rem; display: flex; flex-direction: column; gap: 0.85rem; }
  .features li { display: flex; align-items: center; gap: 0.65rem; font-size: 0.92rem; color: var(--color-text-medium); }
  .plan-card.popular .features li { color: rgba(255,255,255,0.8); }
  .features li svg { flex-shrink: 0; }
  .plan-btn { display: block; text-align: center; padding: 0.85rem 1.5rem; border-radius: 10px; text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: all 0.3s; background: #f1f5f9; color: var(--color-text-dark); }
  .plan-btn:hover { background: #e2e8f0; transform: translateY(-1px); }
  .plan-btn.primary-btn { background: var(--color-primary-green); color: white; box-shadow: 0 4px 14px rgba(21,198,59,0.3); }
  .plan-btn.primary-btn:hover { background: #12ad33; }
  @media (max-width: 992px) { .pricing-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; } .plan-card.popular { transform: none; } .plan-card.popular:hover { transform: translateY(-6px); } h2 { font-size: 2.2rem; } }
  @media (max-width: 768px) { .pricing { padding: 4rem 0; } h2 { font-size: 2rem; } .pricing-subtitle { font-size: 1rem; } .amount { font-size: 2.8rem; } }
</style>
