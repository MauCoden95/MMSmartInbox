---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard de Visualizaciones" description="Privado">
  <main class="stats-container">
    <div class="card" data-aos="fade-up">
        <h1>Dashboard Maestro 👁️</h1>
        <p>Esta ruta es confidencial. Solo tú puedes ver esto.</p>

        <div class="counter-box">
            <h2 id="numero-visitas">Cargando...</h2>
            <span>Visitas Únicas Totales</span>
        </div>
        
        <p class="foot-note">Los datos se almacenan de forma segura y se actualizan con cada visita real única.</p>
    </div>
  </main>
</Layout>

<script is:inline>
  async function cargarVisitas() {
      const elemento = document.getElementById('numero-visitas');
      try {
          // Obtenemos el valor de la API pública
          const res = await fetch('https://api.counterapi.dev/v1/mmsmartinbox_app/visitas_totales');
          
          if (!res.ok) throw new Error('Error al conectar');
          
          const data = await res.json();
          // Actualizamos el número, usando .toLocaleString para que se vea como 1,000 en vez de 1000
          elemento.innerText = data.count.toLocaleString();
      } catch (e) {
          elemento.innerText = "Error";
          console.error("No se pudo cargar el contador:", e);
      }
  }
  
  cargarVisitas();
</script>

<style>
  .stats-container {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 80vh;
      background-color: var(--color-bg);
      padding: 2rem;
  }
  .card {
      background: white;
      padding: 3rem;
      border-radius: 1rem;
      box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
      border: 1px solid #e2e8f0;
      text-align: center;
      max-width: 500px;
      width: 100%;
  }
  h1 {
      color: var(--color-text-dark);
      margin-bottom: 0.5rem;
      font-size: 2rem;
  }
  p {
      color: var(--color-text-medium);
      margin-bottom: 2rem;
  }
  .counter-box {
      background: linear-gradient(135deg, var(--color-primary-blue) 0%, #2528a4 100%);
      color: white;
      padding: 2rem;
      border-radius: 0.75rem;
      box-shadow: 0 4px 15px rgba(58, 61, 238, 0.3);
      margin-bottom: 1.5rem;
  }
  .counter-box h2 {
      font-size: 4rem;
      margin-bottom: 0.5rem;
      font-weight: 800;
  }
  .counter-box span {
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      opacity: 0.9;
      font-weight: 500;
  }
  .foot-note {
      font-size: 0.8rem;
      color: var(--color-text-light);
      margin-top: 1rem;
      margin-bottom: 0;
  }
</style>
