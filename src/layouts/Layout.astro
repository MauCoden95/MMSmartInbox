---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import QuoteModal from '../components/QuoteModal.astro';
import TrialModal from '../components/TrialModal.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { 
	title = "MM SmartInbox | Automatización de Ventas con IA",
	description = "Centralizá tus mensajes de WhatsApp, Instagram y Facebook. Nuestra IA Nova clasifica tus prospectos y escala tus ventas automáticamente.",
	image = "/images/Banner.png",
	canonicalURL = "https://mmsmartinbox.com" // Cambiar por la URL real cuando esté definida
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="chatbot, inteligencia artificial, ventas, whatsapp automation, crm, inbox inteligente, pymes" />
		<link rel="canonical" href={canonicalURL} />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, canonicalURL)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, canonicalURL)} />
		
		<!-- AOS Animation Library -->
		<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
	</head>
	<body>
		<Header />
		<div class="header-spacer"></div>
		<slot />
		<Footer />
		<ChatWidget />
		<QuoteModal />
		<TrialModal />

		<!-- AOS Script -->
		<script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
		<script is:inline>
			// Inicializar AOS
			document.addEventListener('DOMContentLoaded', () => {
				if (typeof AOS !== 'undefined') {
					AOS.init({
						duration: 800,
						once: true,
						offset: 100,
						easing: 'ease-out-cubic'
					});
				}
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		--color-primary-blue: #3A3DEE;
		--color-primary-green: #15C63B;
		--color-text-dark: #0f172a;
		--color-text-medium: #475569;
		--color-text-light: #64748B;
		--color-bg: #FFFFFF;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html, body {
		font-family: 'Inter', sans-serif;
		background-color: var(--color-bg);
		color: var(--color-text-dark);
		width: 100%;
		min-height: 100%;
		scroll-behavior: smooth;
		overflow-x: hidden;
	}

	.header-spacer {
		height: 110px;
	}

	/* Scrollbar Personalizado */
	::-webkit-scrollbar {
		width: 12px;
	}

	::-webkit-scrollbar-track {
		background: #f1f5f9; /* Gris claro de fondo */
	}

	::-webkit-scrollbar-thumb {
		background: var(--color-primary-green); /* Verde principal */
		border-radius: 10px;
		border: 3px solid #f1f5f9; /* Crea un efecto de separación */
	}

	::-webkit-scrollbar-thumb:hover {
		background: #12ad33; /* Un verde un poco más oscuro al pasar el mouse */
	}

	/* Soporte para Firefox */
	* {
		scrollbar-width: thin;
		scrollbar-color: var(--color-primary-green) #f1f5f9;
	}
</style>
